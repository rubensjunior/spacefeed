<!-- Wappler include head-page="layouts/main" fontawesome_5="cdn" bootstrap5="local" is="dmx-app" id="novocliente" appConnect="local" components="{dmxDataTraversal:{},dmxValidator:{},dmxFormatter:{}}" -->
<meta name="ac:route" content="/novo-cliente">
<dmx-value id="planoBase"></dmx-value>
<dmx-data-detail id="data_detail1" dmx-bind:data="listagemPlanos.data.queryPlanos" key="id_plano"></dmx-data-detail>
<dmx-serverconnect id="listagemPlanos" url="/api/financeiro/listar-planos"></dmx-serverconnect>
<dmx-value id="resposta" dmx-bind:value="0"></dmx-value>
<dmx-value id="currentStep" dmx-bind:value="1"></dmx-value>

<div class="auth-container d-flex align-items-center">
    <div class="auth-content">
        <!-- Logo - Always visible with animation -->
        <div class="container">
            <div class="text-center mb-4">
                <img src="/assets/images/spacefeed-white.png" alt="Spacefeed Logo" class="img-fluid" style="max-width: 200px;" width="160">
            </div>
        </div>

        <div class="container">
            <div class="auth-header" dmx-show="resposta.value == 0">
                <h1>Criar conta</h1>
                <p>O Spacefeed é a plataforma de comunicação institucional que aproxima alunos e equipe do polo por meio de uma experiência moderna, no estilo rede social.</p>
            </div>

            <!-- Progress Bar (só aparece após validação do CNPJ) -->
            <div class="progress-steps mb-4" dmx-show="resposta.value == 4">
                <div class="progress" role="progressbar">
                    <div class="progress-bar" dmx-bind:style="'width: ' + ((currentStep.value - 1) * 33.33) + '%'"></div>
                </div>
                <div class="steps">
                    <div class="step" dmx-class:active="currentStep.value >= 1" dmx-class:completed="currentStep.value > 1">
                        <div class="step-circle">1</div>
                        <div class="step-label">Empresa</div>
                    </div>
                    <div class="step" dmx-class:active="currentStep.value >= 2" dmx-class:completed="currentStep.value > 2">
                        <div class="step-circle">2</div>
                        <div class="step-label">Endereço</div>
                    </div>
                    <div class="step" dmx-class:active="currentStep.value >= 3" dmx-class:completed="currentStep.value > 3">
                        <div class="step-circle">3</div>
                        <div class="step-label">Usuário</div>
                    </div>
                    <div class="step" dmx-class:active="currentStep.value >= 4" dmx-class:completed="currentStep.value > 4">
                        <div class="step-circle">4</div>
                        <div class="step-label">Plano</div>
                    </div>
                </div>
            </div>

            <!-- Validação inicial do CNPJ -->
            <form id="validarFormEmpresa" method="post" is="dmx-serverconnect-form" action="/api/signup/validacao-cnpj" dmx-on:success="resposta.setValue(validarFormEmpresa.data.respostaStatus)" dmx-show="resposta.value == 0">
                <div class="card">
                    <div class="card-header">
                        <h5 class="mb-0">Consulta CNPJ</h5>
                    </div>
                    <div class="card-body">
                        <div class="form-group">
                            <label for="verificaCnpj" class="form-label">CNPJ</label>
                            <input type="text" class="form-control form-control-lg" id="verificaCnpj" name="verificaCnpj" required="" data-msg-required="Por favor, informe o CNPJ para verificação.">
                        </div>
                    </div>
                </div>
                <div class="navigation">
                    <div class="d-grid">
                        <button type="submit" class="btn btn-primary btn-lg">Consultar CNPJ</button>
                    </div>
                </div>
            </form>

            <!-- Formulário principal (aparece após validação do CNPJ) -->
            <form id="cadastroUnificadoForm" is="dmx-serverconnect-form" method="post" action="/api/signup/criar-conta-com-plano" dmx-show="resposta.value == 4" class="needs-validation">
                <!-- Informações da Empresa -->
                <div class="card" dmx-show="currentStep.value === 1">
                    <div class="card-header">
                        <h5 class="mb-0">Informações da Empresa</h5>
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-md-8">
                                <label for="razaoSocial" class="form-label">Razão Social</label>
                                <input type="text" class="form-control form-control-lg" id="razaoSocial" name="razaoSocial" required="" data-msg-required="Por favor, informe a razão social.">
                            </div>
                            <div class="col-md-4">
                                <label for="cnpj" class="form-label">CNPJ</label>
                                <input type="text" class="form-control form-control-lg" id="cnpj" name="cnpj" required="" data-msg-required="Por favor, informe o CNPJ.">
                            </div>
                            <div class="col-md-8">
                                <label for="nomeFantasia" class="form-label">Nome Fantasia</label>
                                <input type="text" class="form-control form-control-lg" id="nomeFantasia" name="nomeFantasia" required="" data-msg-required="Por favor, informe o nome fantasia.">
                            </div>
                            <div class="col-md-4">
                                <label for="whatsapp" class="form-label">WhatsApp</label>
                                <input type="text" class="form-control form-control-lg" id="whatsapp" name="whatsapp" required="" data-msg-required="Por favor, informe o WhatsApp.">
                            </div>
                            <div class="col-md-6">
                                <label for="nome_polo" class="form-label">Nome do Polo</label>
                                <input type="text" class="form-control form-control-lg" id="nome_polo" name="nome_polo" required="" data-msg-required="Por favor, informe o nome do polo.">
                            </div>
                        </div>
                    </div>
                </div>
                <div class="navigation" dmx-show="currentStep.value === 1">
                    <div class="d-grid">
                        <button type="button" class="btn btn-primary" dmx-on:click="currentStep.setValue(2)">Próximo<i class="fas fa-arrow-right ms-2"></i></button>
                    </div>
                </div>

                <!-- Endereço -->
                <div class="card" dmx-show="currentStep.value === 2">
                    <div class="card-header">
                        <h5 class="mb-0">Endereço</h5>
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-md-3">
                                <label for="cep" class="form-label">CEP</label>
                                <input type="text" class="form-control form-control-lg" id="cep" name="cep" required="" data-msg-required="Por favor, informe o CEP.">
                            </div>
                            <div class="col-md-7">
                                <label for="logradouro" class="form-label">Logradouro</label>
                                <input type="text" class="form-control form-control-lg" id="logradouro" name="logradouro" required="" data-msg-required="Por favor, informe o logradouro.">
                            </div>
                            <div class="col-md-2">
                                <label for="numero" class="form-label">Número</label>
                                <input type="text" class="form-control form-control-lg" id="numero" name="numero" required="" data-msg-required="Por favor, informe o número.">
                            </div>
                            <div class="col-md-12">
                                <label for="complemento" class="form-label">Complemento</label>
                                <input type="text" class="form-control form-control-lg" id="complemento" name="complemento">
                            </div>
                            <div class="col-md-4">
                                <label for="bairro" class="form-label">Bairro</label>
                                <input type="text" class="form-control form-control-lg" id="bairro" name="bairro" required="" data-msg-required="Por favor, informe o bairro.">
                            </div>
                            <div class="col-md-6">
                                <label for="cidade" class="form-label">Cidade</label>
                                <input type="text" class="form-control form-control-lg" id="cidade" name="cidade" required="" data-msg-required="Por favor, informe a cidade.">
                            </div>
                            <div class="col-md-2">
                                <label for="uf" class="form-label">UF</label>
                                <input type="text" class="form-control form-control-lg" id="uf" name="uf" required="" data-msg-required="Por favor, informe a UF.">
                            </div>
                        </div>
                    </div>
                </div>
                <div class="navigation" dmx-show="currentStep.value === 2">
                    <button type="button" class="btn btn-outline-primary" dmx-on:click="currentStep.setValue(1)"><i class="fas fa-arrow-left me-2"></i>Voltar</button>
                    <button type="button" class="btn btn-primary" dmx-on:click="currentStep.setValue(3)">Próximo<i class="fas fa-arrow-right ms-2"></i></button>
                </div>

                <!-- Usuário Administrador -->
                <div class="card" dmx-show="currentStep.value === 3">
                    <div class="card-header">
                        <h5 class="mb-0">Usuário Administrador</h5>
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label for="email" class="form-label">E-mail</label>
                                <input type="email" class="form-control form-control-lg" id="email" name="email" required="" data-msg-required="Por favor, informe o e-mail." data-msg-email="Por favor, informe um e-mail válido.">
                            </div>
                            <div class="col-md-6">
                                <label for="nome" class="form-label">Nome</label>
                                <input type="text" class="form-control form-control-lg" id="nome" name="nome" required="" data-msg-required="Por favor, informe o nome.">
                            </div>
                            <div class="col-md-6">
                                <label for="nome_tratamento" class="form-label">Nome de Tratamento</label>
                                <input type="text" class="form-control form-control-lg" id="nome_tratamento" name="nome_tratamento" required="" data-msg-required="Por favor, informe o nome de tratamento.">
                            </div>
                            <div class="col-md-6">
                                <label for="senha" class="form-label">Senha</label>
                                <input type="password" class="form-control form-control-lg" id="senha" name="senha" required="" data-msg-required="Por favor, informe a senha.">
                            </div>
                            <div class="col-md-6">
                                <label for="confirmarSenha" class="form-label">Confirmar Senha</label>
                                <input type="password" class="form-control form-control-lg" id="confirmarSenha" name="confirmarSenha" required="" data-rule-equalto="#senha" data-msg-equalto="As senhas não conferem." data-msg-required="Por favor, confirme a senha.">
                            </div>
                        </div>
                    </div>
                </div>
                <div class="navigation" dmx-show="currentStep.value === 3">
                    <button type="button" class="btn btn-outline-primary" dmx-on:click="currentStep.setValue(2)"><i class="fas fa-arrow-left me-2"></i>Voltar</button>
                    <button type="button" class="btn btn-primary" dmx-on:click="currentStep.setValue(4)">Próximo<i class="fas fa-arrow-right ms-2"></i></button>
                </div>

                <!-- Plano e Pagamento -->
                <div class="card" dmx-show="currentStep.value === 4">
                    <div class="card-header">
                        <h5 class="mb-0">Plano e Pagamento</h5>
                    </div>
                    <div class="card-body">
                        <div class="row g-3 mb-4">
                            <div class="col-md-8">
                                <label for="plano" class="form-label">Plano</label>
                                <select id="plano" class="form-select form-select-lg" name="plano" optionvalue="id_plano" dmx-bind:options="listagemPlanos.data.queryPlanos" optiontext="nome+' - '+valor_base" dmx-on:changed="data_detail1.select(selectedValue);planoBase.setValue(data_detail1.data.valor_polo_extra)" required="" data-msg-required="Por favor, selecione um plano.">
                                    <option value="">Selecione um plano</option>
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label for="poloAdicional" class="form-label">Polos Adicionais</label>
                                <div class="input-group">
                                    <input id="poloAdicional" name="poloAdicional" type="number" min="0" class="form-control form-control-lg" value="0" required="" data-rule-number="true" data-rule-digits="true" data-rule-min="0" data-msg-required="Por favor, informe o número de polos adicionais." data-msg-number="Por favor, digite um número válido." data-msg-digits="Por favor, digite apenas números inteiros." data-msg-min="O número de polos adicionais não pode ser negativo.">
                                    <span class="input-group-text" dmx-text="(data_detail1.data ? data_detail1.data.valor_polo_extra * poloAdicional.value : 0).formatCurrency('R$ ', '.', ',', 2)"></span>
                                </div>
                            </div>
                        </div>

                        <!-- Descrição do Plano -->
                        <div class="plan-description mb-4" dmx-show="data_detail1.data">
                            <p class="mb-0" dmx-text="data_detail1.data.descricao"></p>
                        </div>

                        <!-- Resumo de Valores -->
                        <div class="pricing-summary mb-4">
                            <div class="d-flex justify-content-between mb-3">
                                <span>Assinatura Mensal</span>
                                <div class="d-flex align-items-center">
                                    <input id="planoAtual" name="planoAtual" type="hidden" dmx-bind:value="data_detail1.data ? data_detail1.data.valor_base*1 : 0">
                                    <span dmx-text="(data_detail1.data ? data_detail1.data.valor_base*1 : 0).formatCurrency('R$ ', '.', ',', 2)"></span>
                                </div>
                            </div>
                            <div class="d-flex justify-content-between mb-3">
                                <span>Polos Adicionais</span>
                                <div class="d-flex align-items-center">
                                    <input id="totalPolos" name="totalPolos" type="hidden" dmx-bind:value="data_detail1.data ? data_detail1.data.valor_polo_extra*poloAdicional.value : 0">
                                    <span dmx-text="(data_detail1.data ? data_detail1.data.valor_polo_extra*poloAdicional.value : 0).formatCurrency('R$ ', '.', ',', 2)"></span>
                                </div>
                            </div>
                            <hr class="my-3">
                            <div class="d-flex justify-content-between">
                                <strong class="h5 mb-0">Total Mensal</strong>
                                <div class="d-flex align-items-center">
                                    <input id="valorFinal" name="valorFinal" type="hidden" dmx-bind:value="data_detail1.data ? (data_detail1.data.valor_polo_extra*poloAdicional.value+data_detail1.data.valor_base*1) : 0">
                                    <strong class="h5 mb-0" dmx-text="(data_detail1.data ? (data_detail1.data.valor_polo_extra*poloAdicional.value+data_detail1.data.valor_base*1) : 0).formatCurrency('R$ ', '.', ',', 2)"></strong>
                                </div>
                            </div>
                        </div>

                        <!-- Termos e Condições -->
                        <div class="legal-text">
                            <p class="mb-2">Ao clicar em "Finalizar Cadastro", você concorda com os <a href="#" class="fw-medium">Termos de Uso</a> e <a href="#" class="fw-medium">Política de Privacidade</a>.</p>
                            <div class="security-info">
                                <i class="fas fa-lock"></i>
                                <span>Pagamento processado de forma segura pelo ASAAS. Não armazenamos nenhuma informação bancária.</span>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="navigation" dmx-show="currentStep.value === 4">
                    <button type="button" class="btn btn-outline-primary" dmx-on:click="currentStep.setValue(3)"><i class="fas fa-arrow-left me-2"></i>Voltar</button>
                    <button type="submit" class="btn btn-primary" dmx-bind:disabled="!valorFinal.value">Finalizar Cadastro<i class="fas fa-check ms-2"></i></button>
                </div>
            </form>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.2/dist/js/bootstrap.bundle.min.js" integrity="sha384-OERcA2EqjJCMA+/3y+gxIOqMEjwtxJY7qPCqsdltbNJuaOe923+mo//f6V8Qbsw3" crossorigin="anonymous"></script>
<script src="https://code.jquery.com/jquery-3.6.1.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery.mask/1.14.16/jquery.mask.js"></script>

<script>
    $('#cep').mask('00000-000');
    $('#whatsapp').mask('(00) 0 0000-0000');
    $('#cnpj').mask('00.000.000/0000-00');
    $('#verificaCnpj').mask('00.000.000/0000-00');
</script>