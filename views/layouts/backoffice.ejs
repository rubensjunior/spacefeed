<!doctype html>
<html lang="pt">

<head>
  <base href="/">
  <script src="/dmxAppConnect/dmxAppConnect.js"></script>
  <meta charset="UTF-8">
  <title>Backoffice - Spacefeed</title>

  <link rel="stylesheet" href="https://use.fontawesome.com/releases/v5.15.4/css/all.css" integrity="sha384-DyZ88mC6Up2uqS4h/KRgHuoeGwBcD4Ng9SiP4dIRy0EXTlnuz47vAwmeGwVChigm" crossorigin="anonymous" />
  <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
  <link rel="stylesheet" href="/bootstrap/5/css/bootstrap.min.css" />
  <link rel="stylesheet" href="/css/style.css" />
  <script src="/dmxAppConnect/dmxRouting/dmxRouting.js" defer></script>
  <script src="/dmxAppConnect/dmxBootstrap5Collapse/dmxBootstrap5Collapse.js" defer></script>
  <script src="/dmxAppConnect/dmxBrowser/dmxBrowser.js" defer></script>
  <link rel="stylesheet" href="/dmxAppConnect/dmxBootstrap5TableGenerator/dmxBootstrap5TableGenerator.css" />
  <script src="/dmxAppConnect/dmxBootstrap5Modal/dmxBootstrap5Modal.js" defer></script>
  <link rel="stylesheet" href="/dmxAppConnect/dmxValidator/dmxValidator.css" />
  <script src="/dmxAppConnect/dmxValidator/dmxValidator.js" defer></script>
  <link rel="stylesheet" href="/dmxAppConnect/dmxNotifications/dmxNotifications.css" />
  <script src="/dmxAppConnect/dmxNotifications/dmxNotifications.js" defer></script>
  <script src="/dmxAppConnect/dmxBootstrap5Toasts/dmxBootstrap5Toasts.js" defer></script>
  <script src="/dmxAppConnect/dmxBootstrap5Navigation/dmxBootstrap5Navigation.js" defer></script>
  <script src="/dmxAppConnect/dmxDataTraversal/dmxDataTraversal.js" defer></script>
</head>

<body is="dmx-app" id="backoffice" class="bg-backoffice">
  <dmx-notifications id="notificacao"></dmx-notifications>
  <div is="dmx-browser" id="navegacao"></div>
  <dmx-serverconnect id="escolherEmpresa" noload="true" url="/api/empresa/selecionar-empresa"></dmx-serverconnect>
  <dmx-serverconnect id="minhasEmpresas" url="/api/empresa/listar-empresas"></dmx-serverconnect>
  <dmx-serverconnect id="identificarUsuario" url="/api/usuario/identificar-usuario"></dmx-serverconnect>
  <dmx-serverconnect id="deslogar" noload="true" url="/api/usuario/logout"></dmx-serverconnect>



  <div class="wappler-block container-fluid vh-100">
    <div class="row h-100">
      <div class="col-md-1 bg-black py-3 px-3 text-center">
        <a class="img-fluid mb-5" href="/backoffice/"><img src="/assets/images/appIcon.ico" class="img-fluid mb-5" width="64" height="64"></a>

        <div class="d-flex flex-column justify-content-center texto-menu-sidebar mb-4">

          <i class="fas fa-building mb-2 fa-lg"></i>
          <a href="/backoffice/empresa" class="texto-menu-sidebar">Empresa</a>

        </div>
        <div class="d-flex flex-column justify-content-center texto-menu-sidebar mb-4">
          <i class="fas fa-user mb-2 fa-lg"></i>
          <a href="/backoffice/colaborador" class="texto-menu-sidebar">Usuários</a>

        </div>
        <div class="d-flex flex-column justify-content-center texto-menu-sidebar mb-4">
          <i class="fas fa-keyboard mb-2 fa-lg"></i>
          <p class="texto-menu-sidebar">Postagens</p>

        </div>
        <div class="d-flex flex-column justify-content-center texto-menu-sidebar mb-4">
          <i class="fas fa-bell mb-2 fa-lg"></i>
          <p class="texto-menu-sidebar">Notificações</p>

        </div>
        <div class="d-flex flex-column justify-content-center texto-menu-sidebar mb-4">
          <i class="fas fa-headset mb-2 fa-lg"></i>
          <p class="texto-menu-sidebar">Suporte</p>

        </div>
        <div class="d-flex flex-column justify-content-center texto-menu-sidebar mb-4">
          <i class="fas fa-sign-out-alt mb-2 fa-lg"></i>
          <a href="" dmx-on:click="deslogar.load({})">Your link title</a>

        </div>

      </div>
      <div class="col-md-11">
        <div class="row bg-white py-3 px-3 border-bottom border-light-subtle align-items-center">
          <div class="col-4 align-self-center">
            <div class="d-flex">
              <div class="d-flex w-75 me-3">
                <select id="listagemEmpresas" class="form-select" name="listagemEmpresas" dmx-bind:options="minhasEmpresas.data.query" optiontext="nome_polo" optionvalue="id_empresa">
                  <option value="" disabled>Selecione uma empresa</option>
                </select>
              </div>
              <div class="d-flex">
                <button id="btn1" class="btn btn-primary" dmx-on:click="escolherEmpresa.load({idempresaselecionada: listagemEmpresas.selectedValue});minhasEmpresas.load({});navegacao.reload()">Selecionar</button>
              </div>
            </div>

          </div>
          <div class="col align-self-center">
            <div class="d-flex justify-content-end flex-row align-items-center">
              <div class="d-flex flex-column justify-content-end p-0 align-items-end">
                <p class="m-0 texto-identificacao-menu text-end">{{identificarUsuario.data.queryUsuario.apelido}}</p>
                <p class="m-0 texto-empresa-menu text-end">{{identificarUsuario.data.queryEmpresaAtual.nome_polo+" | "+identificarUsuario.data.queryUsuario.email}}</p>
              </div>



              <div class="d-flex mx-4 align-items-center shadow">
                <img class="img-fluid rounded-2" width="40" height="40" src="/assets/images/avatar.png">
              </div><i class="fas fa-bell fa-lg text-info"></i>
            </div>
          </div>
        </div>
        <div class="row py-3 px-3">
          <div class="col"><%- await include(content, locals); %></div>
        </div>


      </div>
    </div>
  </div>
  <script src="/bootstrap/5/js/bootstrap.bundle.min.js"></script>
</body>

</html>