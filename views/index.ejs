<!-- Wappler include head-page="layouts/main" fontawesome_5="cdn" is="dmx-app" id="index" appConnect="local" components="{dmxBrowser:{},dmxNotifications:{},dmxValidator:{},dmxDataTraversal:{},dmxFormatter:{}}" bootstrap5="local" -->

<div class="auth-container d-flex align-items-center justify-content-center">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-4">
                <div class="auth-header">
                    <img src="/assets/images/spacefeed-white.png" class="img-fluid mb-2" width="200">
                </div>

                <div class="card">
                    <div class="card-body p-4">
                        <form id="loginForm" is="dmx-serverconnect-form" method="post" action="/api/auth/login">
                            <div class="form-group mb-4">
                                <label for="email" class="form-label">E-mail</label>
                                <input type="email" id="email" class="form-control form-control-lg" name="email" required data-msg-required="Por favor, informe seu e-mail" data-msg-email="Por favor, informe um e-mail válido">
                            </div>

                            <div class="form-group mb-4">
                                <label for="senha" class="form-label">Senha</label>
                                <input type="password" id="senha" class="form-control form-control-lg" name="senha" required data-msg-required="Por favor, informe sua senha">
                            </div>

                            <div class="mb-4">
                                <div class="d-flex align-items-center justify-content-center">
                                    <div>
                                        <a href="/recuperar-senha" class="text-decoration-none">Recuperar senha</a>
                                    </div>
                                    <div>
                                        <span class="mx-2 text-muted">|</span>
                                        <a href="/novo-cliente" class="text-decoration-none">Criar conta</a>
                                    </div>
                                </div>
                            </div>

                            <!-- Error message -->
                            <div class="alert alert-danger d-none" id="loginError" role="alert">
                                <div class="d-flex">
                                    <div class="flex-shrink-0">
                                        <i class="fas fa-exclamation-circle mt-1"></i>
                                    </div>
                                    <div class="flex-grow-1 ms-3">
                                        <span id="errorMessage">Erro ao fazer login. Verifique suas credenciais.</span>
                                    </div>
                                </div>
                            </div>

                            <div class="form-group">
                                <button id="submitButton" class="btn btn-primary btn-lg w-100" type="submit">
                                    <span dmx-hide="loginForm.state.executing">Fazer login</span>
                                    <span dmx-show="loginForm.state.executing">
                                        <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                                        Entrando...
                                    </span>
                                </button>
                            </div>

                            <!-- Error message -->
                            <div class="mt-3 text-danger text-center" dmx-show="loginForm.lastError">
                                <small dmx-text="loginForm.lastError.message"></small>
                            </div>
                        </form>
                    </div>
                </div>

                <!-- Links úteis -->
                <div class="text-center mt-4">
                    <p class="text-white mb-0">
                        <small>Problemas para acessar? Entre em contato com o <a href="mailto:suporte@spacefeed.app" class="text-white text-decoration-underline">suporte</a></small>
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

<meta name="ac:route" content="/">