<!-- Wappler include head-page="layouts/backoffice" fontawesome_5="cdn" bootstrap5="local" is="dmx-app" id="empresa" appConnect="local" components="{dmxBootstrap5TableGenerator:{},dmxBootstrap5Modal:{},dmxValidator:{},dmxDataTraversal:{}}" -->



<dmx-data-detail id="data_empresa" dmx-bind:data="minhasEmpresas.data.query" key="id_empresa"></dmx-data-detail>
<div class="modal" id="criarModalEmpresa" is="dmx-bs5-modal" tabindex="-1">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header py-4">
                <h5 class="modal-title">Criar nova empresa</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close" dmx-on:click="cadastrarFormEmpresa.reset()"></button>
            </div>
            <div class="modal-body px-4">
                <form id="cadastrarFormEmpresa" is="dmx-serverconnect-form" method="post" action="/api/empresa/criar-empresa" dmx-on:error="notificacao.danger(criarModalEmpresa.cadastrarFormEmpresa.lastError.status+criarModalEmpresa.cadastrarFormEmpresa.lastError.message+criarModalEmpresa.cadastrarFormEmpresa.lastError.response)" dmx-on:success="notificacao.success('Cadastro realizado com sucesso!');navegacao.reload()" dmx-on:invalid="run({run:{outputType:'text',action:`notificacao.warning(\'Este CNPJ já está cadastrado. Entre em contato com o suporte para mais informações: suporte@spacefeed.app.\')`}})">

                    <div class="row">
                        <div class="col">
                            <div class="form-group mb-3"> <label for="editrazaoSocial" class="form-label">Razão social</label>
                                <input type="text" class="form-control" id="razaoSocial" name="razaoSocial" aria-describedby="input1_help" required="" data-msg-required="Este é um campo obrigatório!">
                            </div>
                        </div>
                        <div class="col">
                            <div class="form-group mb-3"> <label for="editnomeFantasia" class="form-label">Nome fantasia</label>
                                <input type="text" class="form-control" id="nomeFantasia" name="nomeFantasia" aria-describedby="input1_help1" required="" data-msg-required="Este é um campo obrigatório!">
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col">
                            <div class="form-group mb-3"> <label for="editnomePolo" class="form-label">Nome do polo</label>
                                <input type="text" class="form-control" id="nomePolo" name="nomePolo" aria-describedby="input1_help2" required="" data-msg-required="Este é um campo obrigatório!">
                            </div>
                        </div>
                        <div class="col">
                            <div class="form-group mb-3"> <label for="editnomePolo" class="form-label">CNPJ</label>
                                <input type="text" class="form-control" id="cnpj" name="cnpj" aria-describedby="input1_help2" required="" data-msg-required="Este é um campo obrigatório!">
                            </div>
                        </div>
                    </div>
                    <div class="form-group mb-3"> <label for="editendereco" class="form-label">Endereço completo com número</label>
                        <input type="text" class="form-control" id="endereco" name="endereco" aria-describedby="input5_help" required="" data-msg-required="Este é um campo obrigatório!">
                    </div>
                    <div class="row">
                        <div class="col">
                            <div class="form-group mb-3"> <label for="editcep" class="form-label">CEP<br></label>
                                <input type="text" class="form-control" id="cep" name="cep" aria-describedby="input1_help3" required="" data-msg-required="Este é um campo obrigatório!">
                            </div>
                        </div>
                        <div class="col">
                            <div class="form-group mb-3"> <label for="editcep" class="form-label">Whatsapp</label>
                                <input type="text" class="form-control" id="whatsapp" name="whatsapp" aria-describedby="input1_help3" required="" data-msg-required="Este é um campo obrigatório!">
                            </div>
                        </div>
                    </div>

                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-primary" dmx-on:click="cadastrarFormEmpresa.submit()">Adicionar</button>
            </div>
        </div>
    </div>
</div>
<meta name="ac:route" content="/backoffice/empresa">
<div class="modal" id="editarModalEmpresa" is="dmx-bs5-modal" tabindex="-1">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header py-4">
                <h5 class="modal-title">Editando: {{data_empresa.data.nome_polo}}</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close" dmx-on:click="editarFormEmpresa.reset();data_empresa.select(0)"></button>
            </div>
            <div class="modal-body px-4">
                <form method="post" id="editarFormEmpresa">

                    <div class="row">
                        <div class="col">
                            <div class="form-group mb-3"> <label for="editrazaoSocial" class="form-label">Razão social</label>
                                <input type="text" class="form-control" id="editrazaoSocial" name="editrazaoSocial" aria-describedby="input1_help" required="" data-msg-required="Este é um campo obrigatório!" dmx-bind:value="data_empresa.data.razao_social">
                            </div>
                        </div>
                        <div class="col">
                            <div class="form-group mb-3"> <label for="editnomeFantasia" class="form-label">Nome fantasia</label>
                                <input type="text" class="form-control" id="editnomeFantasia" name="editnomeFantasia" aria-describedby="input1_help1" required="" data-msg-required="Este é um campo obrigatório!" dmx-bind:value="data_empresa.data.nome_fantasia">
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col">
                            <div class="form-group mb-3"> <label for="editnomePolo" class="form-label">Nome do polo</label>
                                <input type="text" class="form-control" id="editnomePolo" name="editnomePolo" aria-describedby="input1_help2" required="" data-msg-required="Este é um campo obrigatório!" dmx-bind:value="data_empresa.data.nome_polo">
                            </div>
                        </div>
                        <div class="col">
                            <div class="form-group mb-3"> <label for="editnomePolo" class="form-label">CNPJ</label>
                                <input type="text" class="form-control" id="editcnpj" name="editcnpj" aria-describedby="input1_help2" required="" data-msg-required="Este é um campo obrigatório!" dmx-bind:value="data_empresa.data.cnpj">
                            </div>
                        </div>
                    </div>
                    <div class="form-group mb-3"> <label for="editendereco" class="form-label">Endereço completo com número</label>
                        <input type="text" class="form-control" id="editendereco" name="editendereco" aria-describedby="input5_help" required="" data-msg-required="Este é um campo obrigatório!" dmx-bind:value="data_empresa.data.endereco">
                    </div>
                    <div class="row">
                        <div class="col">
                            <div class="form-group mb-3"> <label for="editcep" class="form-label">CEP<br></label>
                                <input type="text" class="form-control" id="editcep" name="editcep" aria-describedby="input1_help3" required="" data-msg-required="Este é um campo obrigatório!" dmx-bind:value="data_empresa.data.cep">
                            </div>
                        </div>
                        <div class="col">
                            <div class="form-group mb-3"> <label for="editcep" class="form-label">Whatsapp</label>
                                <input type="text" class="form-control" id="editwhatsapp" name="editwhatsapp" aria-describedby="input1_help3" required="" data-msg-required="Este é um campo obrigatório!" dmx-bind:value="data_empresa.data.whatsapp">
                            </div>
                        </div>
                    </div>

                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-primary" dmx-on:click="editarFormEmpresa.submit()">Atualizar</button>
            </div>
        </div>
    </div>
</div>
<main>
    <div class="row mb-4">
        <div class="col align-self-center">
            <h4 class="m-0">Gestão de empresas</h4>
        </div>
        <div class="col text-end align-self-center">
            <button id="btn1" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#criarModalEmpresa">Adicionar</button>
        </div>
    </div>
    <div class="row m-0">
        <div class="col p-3 bg-white rounded-3">
            <table class="table">
                <thead>
                    <tr>
                        <th class="titulo-tabela py-3">POLO</th>
                        <th class="titulo-tabela py-3">CNPJ</th>
                        <th class="titulo-tabela py-3">ENDEREÇO</th>
                        <th class="titulo-tabela py-3">WHATSAPP</th>
                        <th class="titulo-tabela py-3">STATUS</th>
                    </tr>
                </thead>
                <tbody is="dmx-repeat" dmx-generator="bs5table" dmx-bind:repeat="minhasEmpresas.data.query" id="tableRepeat2">
                    <tr>
                        <td dmx-text="nome_polo" class="texto-celula fw-semibold text-decoration-underline py-3 cursor-pointer" dmx-on:click="data_empresa.select(id_empresa);editarModalEmpresa.show()"></td>
                        <td dmx-text="cnpj" class="texto-celula py-3"></td>
                        <td dmx-text="endereco+&quot; - &quot;+cep" class="texto-celula py-3"></td>
                        <td dmx-text="whatsapp" class="texto-celula py-3"></td>
                        <td dmx-text="status_empresa" class="texto-celula py-3"></td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</main>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.2/dist/js/bootstrap.bundle.min.js" integrity="sha384-OERcA2EqjJCMA+/3y+gxIOqMEjwtxJY7qPCqsdltbNJuaOe923+mo//f6V8Qbsw3" crossorigin="anonymous"></script>
<script src="https://code.jquery.com/jquery-3.6.1.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery.mask/1.14.16/jquery.mask.js"></script>

<script>
    $('#cep').mask('00000-000');
    $('#whatsapp').mask('(00) 0 0000-0000');
    $('#cnpj').mask('00.000.000/0000-00');
    $('#editcep').mask('00000-000');
    $('#editwhatsapp').mask('(00) 0 0000-0000');
    $('#editcnpj').mask('00.000.000/0000-00');
</script>