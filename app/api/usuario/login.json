{
  "meta": {
    "options": {
      "linkedFile": "/views/index.ejs",
      "linkedForm": "loginForm"
    },
    "$_POST": [
      {
        "type": "text",
        "fieldName": "email",
        "options": {
          "rules": {
            "core:required": {
              "param": "",
              "message": "Este é um campo obrigatório."
            },
            "core:email": {
              "param": "",
              "message": "Insira um e-mail válido."
            }
          }
        },
        "name": "email"
      },
      {
        "type": "text",
        "fieldName": "senha",
        "options": {
          "rules": {
            "core:required": {
              "param": "",
              "message": "Este é um campo obrigatório."
            }
          }
        },
        "name": "senha"
      }
    ]
  },
  "exec": {
    "steps": {
      "name": "identity",
      "module": "auth",
      "action": "login",
      "options": {
        "provider": "auth",
        "username": "{{$_POST.email}}",
        "password": "{{$_POST.senha}}"
      },
      "output": true,
      "meta": []
    }
  }
}