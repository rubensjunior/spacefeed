            "query": "insert into \"empresas\" (\"cep\", \"cnpj\", \"endereco\", \"nome_fantasia\", \"nome_polo\", \"razao_social\", \"status_empresa\", \"whatsapp\") values (?, ?, ?, ?, ?, ?, ?, ?)",
            "params": [
              {
                "name": ":P1",
                "type": "expression",
                "value": "{{$_POST.razaoSocial}}",
                "test": ""
              },
              {
                "name": ":P2",
                "type": "expression",
                "value": "{{$_POST.nomeFantasia}}",
                "test": ""
              },
              {
                "name": ":P3",
