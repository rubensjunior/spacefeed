        "options": {
          "connection": "supabase",
          "sql": {
            "type": "insert",
            "values": [
              {
                "table": "usuarios_empresas",
                "column": "ref_id_usuario",
                "type": "text",
                "value": "{{identity}}"
              },
              {
                "table": "usuarios_empresas",
                "column": "ref_id_empresa",
