{
  "meta": {
    "options": {
      "linkedFile": "/views/sing-up.ejs",
      "linkedForm": "signupForm"
    },
    "$_POST": [
      {
        "type": "text",
        "fieldName": "razaoSocial",
        "name": "razaoSocial"
      },
      {
        "type": "text",
        "fieldName": "nomeFantasia",
        "name": "nomeFantasia"
      },
      {
        "type": "text",
        "fieldName": "nomePolo",
        "name": "nomePolo"
      },
      {
        "type": "text",
        "fieldName": "cnpj",
        "name": "cnpj"
      },
      {
        "type": "text",
        "fieldName": "endereco",
        "name": "endereco"
      },
      {
        "type": "text",
        "fieldName": "cep",
        "name": "cep"
      },
      {
        "type": "text",
        "fieldName": "whatsapp",
        "name": "whatsapp"
      },
      {
        "type": "text",
        "fieldName": "nomeCompleto",
        "name": "nomeCompleto"
      },
      {
        "type": "text",
        "fieldName": "tratamento",
        "name": "tratamento"
      },
      {
        "type": "text",
        "fieldName": "email",
        "name": "email"
      },
      {
        "type": "text",
        "fieldName": "senha",
        "name": "senha"
      },
      {
        "type": "text",
        "fieldName": "confirmarSenha",
        "name": "confirmarSenha"
      }
    ]
  },
  "exec": {
    "steps": [
      {
        "name": "hash",
        "module": "crypto",
        "action": "passwordHash",
        "options": {
          "algo": "argon2id",
          "password": "{{$_POST.senha}}"
        },
        "outputType": "text"
      },
      {
        "name": "validateCNPJ",
        "module": "validator",
        "action": "validate",
        "options": {
          "data": [
            {
              "name": "validate_1",
              "value": "{{$_POST.cnpj}}",
              "rules": {
                "db:notexists": {
                  "param": {
                    "connection": "supabase",
                    "table": "empresas",
                    "column": "cnpj"
                  },
                  "message": "Este CNPJ já está cadastrado. Entre em contato com o nosso time de suporte!"
                }
              },
              "fieldName": "cnpj"
            },
            {
              "name": "validate_2",
              "value": "{{$_POST.email}}",
              "rules": {
                "db:notexists": {
                  "param": {
                    "connection": "supabase",
                    "table": "usuarios",
                    "column": "email"
                  },
                  "message": "Este e-mail já foi usado em uma conta."
                }
              },
              "fieldName": "email"
            }
          ]
        }
      },
      {
        "name": "insertCriarConta",
        "module": "dbupdater",
        "action": "insert",
        "options": {
          "connection": "supabase",
          "sql": {
            "type": "insert",
            "values": [
              {
                "table": "empresas",
                "column": "razao_social",
                "type": "text",
                "value": "{{$_POST.razaoSocial}}"
              },
              {
                "table": "empresas",
                "column": "nome_fantasia",
                "type": "text",
                "value": "{{$_POST.nomeFantasia}}"
              },
              {
                "table": "empresas",
                "column": "nome_polo",
                "type": "text",
                "value": "{{$_POST.nomePolo}}"
              },
              {
                "table": "empresas",
                "column": "cnpj",
                "type": "text",
                "value": "{{$_POST.cnpj}}"
              },
              {
                "table": "empresas",
                "column": "endereco",
                "type": "text",
                "value": "{{$_POST.endereco}}"
              },
              {
                "table": "empresas",
                "column": "cep",
                "type": "text",
                "value": "{{$_POST.cep}}"
              },
              {
                "table": "empresas",
                "column": "whatsapp",
                "type": "text",
                "value": "{{$_POST.whatsapp}}"
              },
              {
                "table": "empresas",
                "column": "status_empresa",
                "type": "text",
                "value": "Ativo"
              }
            ],
            "table": "empresas",
            "returning": "id_empresa",
            "query": "insert into \"empresas\" (\"cep\", \"cnpj\", \"endereco\", \"nome_fantasia\", \"nome_polo\", \"razao_social\", \"status_empresa\", \"whatsapp\") values (?, ?, ?, ?, ?, ?, ?, ?)",
            "params": [
              {
                "name": ":P1",
                "type": "expression",
                "value": "{{$_POST.razaoSocial}}",
                "test": ""
              },
              {
                "name": ":P2",
                "type": "expression",
                "value": "{{$_POST.nomeFantasia}}",
                "test": ""
              },
              {
                "name": ":P3",
                "type": "expression",
                "value": "{{$_POST.nomePolo}}",
                "test": ""
              },
              {
                "name": ":P4",
                "type": "expression",
                "value": "{{$_POST.cnpj}}",
                "test": ""
              },
              {
                "name": ":P5",
                "type": "expression",
                "value": "{{$_POST.endereco}}",
                "test": ""
              },
              {
                "name": ":P6",
                "type": "expression",
                "value": "{{$_POST.cep}}",
                "test": ""
              },
              {
                "name": ":P7",
                "type": "expression",
                "value": "{{$_POST.whatsapp}}",
                "test": ""
              }
            ]
          }
        },
        "meta": [
          {
            "name": "identity",
            "type": "text"
          },
          {
            "name": "affected",
            "type": "number"
          }
        ]
      },
      {
        "name": "insertUsuario",
        "module": "dbupdater",
        "action": "insert",
        "options": {
          "connection": "supabase",
          "sql": {
            "type": "insert",
            "values": [
              {
                "table": "usuarios",
                "column": "nome_completo",
                "type": "text",
                "value": "{{$_POST.nomeCompleto}}"
              },
              {
                "table": "usuarios",
                "column": "apelido",
                "type": "text",
                "value": "{{$_POST.tratamento}}"
              },
              {
                "table": "usuarios",
                "column": "email",
                "type": "text",
                "value": "{{$_POST.email}}"
              },
              {
                "table": "usuarios",
                "column": "ref_id_empresa_ativa",
                "type": "text",
                "value": "{{insertCriarConta.identity}}"
              },
              {
                "table": "usuarios",
                "column": "senha",
                "type": "text",
                "value": "{{hash}}"
              },
              {
                "table": "usuarios",
                "column": "tipo_usuario",
                "type": "text",
                "value": "Colaborador"
              }
            ],
            "table": "usuarios",
            "returning": "id_usuario",
            "query": "insert into \"usuarios\" (\"apelido\", \"email\", \"nome_completo\", \"ref_id_empresa_ativa\", \"senha\", \"tipo_usuario\") values (?, ?, ?, ?, ?, ?) returning \"id_usuario\"",
            "params": [
              {
                "name": ":P1",
                "type": "expression",
                "value": "{{$_POST.nomeCompleto}}",
                "test": ""
              },
              {
                "name": ":P2",
                "type": "expression",
                "value": "{{$_POST.tratamento}}",
                "test": ""
              },
              {
                "name": ":P3",
                "type": "expression",
                "value": "{{$_POST.email}}",
                "test": ""
              },
              {
                "name": ":P4",
                "type": "expression",
                "value": "{{insertCriarConta.identity}}",
                "test": ""
              },
              {
                "name": ":P5",
                "type": "expression",
                "value": "{{hash}}",
                "test": ""
              }
            ]
          }
        },
        "meta": [
          {
            "name": "identity",
            "type": "text"
          },
          {
            "name": "affected",
            "type": "number"
          }
        ]
      },
      {
        "name": "insertUsuarioEmpresa",
        "module": "dbupdater",
        "action": "insert",
        "options": {
          "connection": "supabase",
          "sql": {
            "type": "insert",
            "values": [
              {
                "table": "usuarios_empresas",
                "column": "ref_id_usuario",
                "type": "text",
                "value": "{{insertUsuario.identity}}"
              },
              {
                "table": "usuarios_empresas",
                "column": "ref_id_empresa",
                "type": "text",
                "value": "{{insertCriarConta.identity}}"
              },
              {
                "table": "usuarios_empresas",
                "column": "cargo_usuario_empresa",
                "type": "text",
                "value": "Administrador"
              },
              {
                "table": "usuarios_empresas",
                "column": "status_usuario",
                "type": "text",
                "value": "Ativo"
              }
            ],
            "table": "usuarios_empresas",
            "returning": "id_usuario_empresa",
            "query": "insert into \"usuarios_empresas\" (\"cargo_usuario_empresa\", \"ref_id_empresa\", \"ref_id_usuario\", \"status_usuario\") values (?, ?, ?, ?)",
            "params": [
              {
                "name": ":P1",
                "type": "expression",
                "value": "{{insertUsuario.identity}}",
                "test": ""
              },
              {
                "name": ":P2",
                "type": "expression",
                "value": "{{insertCriarConta.identity}}",
                "test": ""
              }
            ]
          }
        },
        "meta": [
          {
            "name": "identity",
            "type": "text"
          },
          {
            "name": "affected",
            "type": "number"
          }
        ]
      }
    ]
  },
  "usedModules": {
    "argon2": "^0.30.2"
  }
}